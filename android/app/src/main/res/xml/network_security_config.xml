<?xml version="1.0" encoding="utf-8"?>
<!--
    MASVS-NETWORK-1: Disable cleartext HTTP traffic.
    CipherOwl communicates exclusively over TLS (Supabase HTTPS).
    Any accidental cleartext request will trigger a NetworkSecurityException
    instead of silently leaking data.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust the system certificate store only (no user-installed CAs) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Supabase domains: TLS-only + certificate pinning (MASVS-NETWORK-2) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">supabase.in</domain>
        <pin-set expiration="2027-06-01">
            <!-- Amazon Root CA 1 (Supabase/AWS infrastructure) -->
            <pin digest="SHA-256">++MBgDH5WGvL9Bcn5Be30cRcL0f5O+NyoXuWtQdX1aI=</pin>
            <!-- Starfield Services Root CA (AWS backup chain) -->
            <pin digest="SHA-256">KwccWaCgrnaw6tsrrSO61FgLacNgG2MMLq8GE6+oP5I=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Allow cleartext for localhost during debug/emulator testing -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
