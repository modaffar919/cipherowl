<?xml version="1.0" encoding="utf-8"?>
<!--
  Autofill suggestion row shown in the Android autofill picker / IME bar.
  Kept intentionally simple so it works as a RemoteViews presentation.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@android:color/white">

    <!-- Owl icon placeholder -->
    <ImageView
        android:id="@+id/autofill_item_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="@null"
        android:scaleType="fitCenter" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <!-- Site / entry title -->
        <TextView
            android:id="@+id/autofill_item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="CipherOwl" />

        <!-- Username / email -->
        <TextView
            android:id="@+id/autofill_item_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="username" />
    </LinearLayout>

</LinearLayout>
